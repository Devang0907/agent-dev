{
  "name": "@devang0907/agent-dev",
  "version": "0.4.4",
  "description": "Minimal terminal coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Devang Rakholiya <rakholiyadevang@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devang0907/agent-dev.git"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "opentui",
    "coding-agent"
  ],
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "bin": {
    "agent": "dist/cli.js"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun run build.ts",
    "start": "bun dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest run --coverage",
    "prepublishOnly": "bun run build",
    "postinstall": "bun scripts/postinstall.js",
    "publish:public": "npm publish --access public"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@opentui/core": "^0.4.2",
    "@opentui/core-win32-x64": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "chalk": "^5.4.1",
    "grammy": "^1.44.0",
    "openai": "^6.44.0",
    "playwright": "^1.61.0",
    "solid-js": "1.9.12",
    "typebox": "^1.0.27"
  },
  "overrides": {
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
