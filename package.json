{
  "name": "@devang0907/agent-dev",
  "version": "0.1.10",
  "description": "Minimal terminal coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Devang Rakholiya <rakholiyadevang@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devang0907/agent-dev.git"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "ink",
    "coding-agent"
  ],
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "bin": {
    "agent": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "publish:public": "npm publish --access public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "ink": "^5.2.0",
    "openai": "^6.44.0",
    "react": "^18.3.1",
    "typebox": "^1.0.27"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
